QUICK-SORT(A, low, high)
    if low < high:
        p ← PARTITION(A, low, high)

        QUICK-SORT(A, low, p - 1)
        QUICK-SORT(A, p + 1, high)

PARTITION(A, low, high)
    pivot ← A[high]      // choose last element as pivot
    i ← low - 1

    for j ← low to high - 1:
        if A[j] ≤ pivot:
            i ← i + 1
            swap A[i] and A[j]

    swap A[i + 1] and A[high]

    return i + 1
